# --- Core ---
PORT=3000
DATABASE_URL=
PGSSL=true
JWT_SECRET=change-this-to-a-long-random-string

# --- Telegram bot (companion bot for Start Bot + Join Channel tasks, and Login Widget) ---
BOT_TOKEN=
BOT_USERNAME=
# Chat ID of the channel/group users must join for the "Join Telegram channel/group" task.
# The bot must be an admin of this chat to detect joins.
JOIN_CHAT_ID=

# --- Admin panel ---
ADMIN_PASSWORD=change-this-password

# --- Fixed X tasks (no automated verification — honor system) ---
X_FOLLOW_LINK=https://x.com/yourhandle
X_FOLLOW_REWARD=20
X_POST_LINK=https://x.com/yourhandle/status/123456789
X_LIKE_REWARD=10
X_REPOST_REWARD=10

# --- Other fixed reward amounts ---
JOIN_CHANNEL_REWARD=20
START_BOT_REWARD=15
REFERRAL_REWARD=12
DAILY_BONUS_REWARD=5
